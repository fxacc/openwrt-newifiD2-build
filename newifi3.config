# Newifi D2 / Newifi3 (D-Team Newifi D2) minimal ImmortalWrt build
# Target: MediaTek MT7621, 32 MB flash, Breed-friendly sysupgrade image
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_d-team_newifi-d2=y

# LuCI Web UI (keep HTTP LuCI to reduce flash usage; add luci-ssl-openssl manually if HTTPS is needed)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_LUCI_LANG_zh_Hans=y

# PassWall2 only
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall2_Nftables_Transparent_Proxy=y
# CONFIG_PACKAGE_luci-app-passwall2_Iptables_Transparent_Proxy is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Haproxy is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Hysteria is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_IPv6_Nat is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_NaiveProxy is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Libev_Server is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Client is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Shadowsocks_Rust_Server is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_ShadowsocksR_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_ShadowsocksR_Libev_Server is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_Simple_Obfs is not set
CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_SingBox=y
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_tuic_client is not set
# CONFIG_PACKAGE_luci-app-passwall2_INCLUDE_V2ray_Plugin is not set

# Required proxy cores only
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y

# Keep sing-box small but retain Hysteria2/Reality-friendly features.
# CONFIG_SING_BOX_BUILD_ACME is not set
# CONFIG_SING_BOX_BUILD_CLASH_API is not set
# CONFIG_SING_BOX_BUILD_DHCP is not set
# CONFIG_SING_BOX_BUILD_EMBEDDED_TOR is not set
# CONFIG_SING_BOX_BUILD_GRPC is not set
# CONFIG_SING_BOX_BUILD_GVISOR is not set
CONFIG_SING_BOX_BUILD_QUIC=y
# CONFIG_SING_BOX_BUILD_TAILSCALE is not set
CONFIG_SING_BOX_BUILD_UTLS=y
# CONFIG_SING_BOX_BUILD_V2RAY_API is not set
# CONFIG_SING_BOX_BUILD_WIREGUARD is not set

# Explicitly exclude heavy/unwanted plugins and services
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-adguardhome is not set
# CONFIG_PACKAGE_luci-app-zerotier is not set
# CONFIG_PACKAGE_openclash is not set
# CONFIG_PACKAGE_adguardhome is not set
# CONFIG_PACKAGE_zerotier is not set

# Do not build extra images/packages beyond this device profile.
# CONFIG_TARGET_MULTI_PROFILE is not set
