# ImmortalWrt 23.05 feeds first: keep Go-based cores (xray-core/sing-box)
# on versions known to build with the 23.05 toolchain.
src-git-full packages https://github.com/immortalwrt/packages.git;openwrt-23.05
src-git-full luci https://github.com/immortalwrt/luci.git;openwrt-23.05
src-git-full routing https://github.com/openwrt/routing.git;openwrt-23.05
src-git-full telephony https://github.com/openwrt/telephony.git;openwrt-23.05

# PassWall2 feeds: provide luci-app-passwall2 and PassWall-only dependencies.
# Keep them after ImmortalWrt packages so duplicate xray-core/sing-box packages
# do not override the 23.05-compatible base-feed versions during feeds install.
src-git passwall_packages https://github.com/Openwrt-Passwall/openwrt-passwall-packages.git;main
src-git passwall2 https://github.com/Openwrt-Passwall/openwrt-passwall2.git;main
