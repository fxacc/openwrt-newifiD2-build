# OpenWrt master feeds for a latest PassWall2-oriented Newifi D2 build.
src-git-full packages https://github.com/openwrt/packages.git;master
src-git-full luci https://github.com/openwrt/luci.git;master
src-git-full routing https://github.com/openwrt/routing.git;master
src-git-full telephony https://github.com/openwrt/telephony.git;master

# PassWall2 and its package/core dependencies. Keep these on main when using
# OpenWrt master so Go/LuCI/package dependencies move together.
src-git passwall_packages https://github.com/Openwrt-Passwall/openwrt-passwall-packages.git;main
src-git passwall2 https://github.com/Openwrt-Passwall/openwrt-passwall2.git;main
